{
  "name": "Example Nostalgia Template",
  "description": "A starter template for nostalgia-themed TikTok carousel content. Fork this and adapt for your niche.",
  "niche": "nostalgia",
  "contentTypes": {
    "showcase": {
      "description": "Showcase a nostalgic item/moment with a hook slide, content slides, and CTA",
      "slides": 6,
      "structure": [
        { "slide": 1, "purpose": "Hook — grab attention with bold text + striking image" },
        { "slide": 2, "purpose": "Context — set the scene, introduce the subject" },
        { "slide": 3, "purpose": "Detail — key information or highlight" },
        { "slide": 4, "purpose": "Detail — another angle or fact" },
        { "slide": 5, "purpose": "Payoff — the emotional peak or reveal" },
        { "slide": 6, "purpose": "CTA — save/share/comment prompt" }
      ]
    },
    "evolution": {
      "description": "Show how something changed over time",
      "slides": 6,
      "structure": [
        { "slide": 1, "purpose": "Hook — 'Watch the evolution of...'" },
        { "slide": 2, "purpose": "Early version" },
        { "slide": 3, "purpose": "Mid version" },
        { "slide": 4, "purpose": "Later version" },
        { "slide": 5, "purpose": "Current/final version" },
        { "slide": 6, "purpose": "CTA — 'Which era was the best?'" }
      ]
    },
    "top-picks": {
      "description": "Curated list of top items in your niche",
      "slides": 6,
      "structure": [
        { "slide": 1, "purpose": "Hook — 'Top 5 [things] you forgot about'" },
        { "slide": 2, "purpose": "Pick #5" },
        { "slide": 3, "purpose": "Pick #4 and #3" },
        { "slide": 4, "purpose": "Pick #2" },
        { "slide": 5, "purpose": "Pick #1 (the best)" },
        { "slide": 6, "purpose": "CTA — 'What would YOUR #1 be?'" }
      ]
    }
  },
  "hookStrategies": [
    { "type": "nostalgia", "pattern": "Remember {item}? 🔥", "effectiveness": "high" },
    { "type": "gatekeeping", "pattern": "Only real ones remember {item}", "effectiveness": "high" },
    { "type": "challenge", "pattern": "Name a better {category}. I'll wait.", "effectiveness": "very-high" },
    { "type": "pov", "pattern": "POV: You just discovered {item} 😱", "effectiveness": "high" },
    { "type": "contradiction", "pattern": "Everyone forgot about {item}. Nobody talks about it.", "effectiveness": "very-high" },
    { "type": "question", "pattern": "Was {item} the best {category} ever? 🤔", "effectiveness": "high" }
  ],
  "hashtagStrategy": {
    "niche": ["#nostalgia", "#throwback", "#remember"],
    "discovery": ["#fyp", "#viral"],
    "maxTotal": 5,
    "note": "2-3 niche hashtags + 1-2 discovery hashtags. Diminishing returns beyond 5."
  },
  "slideDesign": {
    "size": { "width": 1024, "height": 1536 },
    "background": { "style": "dark-gradient", "colors": ["#0d1117", "#1a1a2e"] },
    "text": { "font": "bold sans-serif", "color": "#ffffff", "hookSize": "large", "bodySize": "medium" },
    "notes": "High contrast text is essential — TikTok users scroll fast. Use 60pt+ for hook text."
  }
}
