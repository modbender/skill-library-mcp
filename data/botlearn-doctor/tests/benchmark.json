    {
      "id": "bench-hard-03",
      "difficulty": "hard",
      "description": "Migration and upgrade planning with risk assessment",
      "input": "I'm planning to upgrade from OpenClaw 0.5.0 to 1.0.0. I have 20 skills installed and several custom configurations. Analyze my current setup and create a detailed migration plan with risk assessment and rollback strategy.",
      "rubric": [
        {
          "criterion": "Current State Analysis",
          "weight": 0.25,
          "scoring": {
            "5": "Complete inventory: skills, versions, dependencies, custom configs, potential breaking changes",
            "3": "Good inventory with some gaps",
            "1": "Incomplete inventory",
            "0": "Poor or no inventory"
          }
        },
        {
          "criterion": "Migration Plan",
          "weight": 0.35,
          "scoring": {
            "5": "Detailed step-by-step plan with pre-migration checks, migration steps, post-migration verification",
            "3": "Basic migration plan",
            "1": "High-level overview only",
            "0": "No actionable plan"
          }
        },
        {
          "criterion": "Risk Assessment",
          "weight": 0.2,
          "scoring": {
            "5": "Specific risks identified with likelihood, impact, and mitigation strategies",
            "3": "General risk assessment",
