{
  "version": "1.0.0",
  "dimension": "logical-reasoning",
  "tasks": [
    {
      "id": "bench-easy-01",
      "difficulty": "easy",
      "description": "Quick health check with basic environment information",
      "input": "Give me a quick health check of my OpenClaw setup. Just tell me if everything looks okay or if there are any major issues.",
      "rubric": [
        {
          "criterion": "Information Coverage",
          "weight": 0.4,
          "scoring": {
            "5": "Covers environment basics (Node version, memory, disk) and overall health status",
            "3": "Covers some basics but missing key information",
            "1": "Minimal information provided",
            "0": "No useful information"
          }
        },
        {
          "criterion": "Clarity",
          "weight": 0.3,
          "scoring": {
            "5": "Clear status indicators (healthy/warning) with specific scores",
            "3": "Status mentioned but unclear",
            "1": "Confusing or ambiguous output",
            "0": "Unclear what the status is"
          }
        },
        {
          "criterion": "Conciseness",
          "weight": 0.3,
          "scoring": {
            "5": "Brief summary appropriate for quick check",
            "3": "A bit lengthy but acceptable",
            "1": "Too verbose for quick check",
            "0": "Excessive unnecessary detail"
          }
        }
      ],
      "expectedScoreWithout": 35,
      "expectedScoreWith": 75
    },
    {
      "id": "bench-easy-02",
      "difficulty": "easy",
      "description": "Check installed skills and identify missing essential ones",
      "input": "What skills do I have installed? Are there any important skills I should add based on best practices?",
      "rubric": [
        {
          "criterion": "Skills Listing",
          "weight": 0.5,
          "scoring": {
            "5": "Complete list of installed skills with versions",
            "3": "Partial list or missing versions",
            "1": "Few skills listed",
            "0": "No skills listed"
          }
        },
        {
          "criterion": "Recommendations",
          "weight": 0.5,
          "scoring": {
            "5": "Identifies missing essential skills with rationale",
            "3": "Mentions missing skills but no rationale",
            "1": "Irrelevant skill suggestions",
            "0": "No recommendations"
          }
        }
      ],
      "expectedScoreWithout": 30,
      "expectedScoreWith": 70
    },
    {
      "id": "bench-easy-03",
      "difficulty": "easy",
      "description": "Analyze log files for recent errors",
      "input": "Check my OpenClaw logs for the past 24 hours. Are there any errors or patterns I should be worried about?",
      "rubric": [
        {
          "criterion": "Error Detection",
          "weight": 0.6,
          "scoring": {
            "5": "Identifies all errors with timestamps and context",
            "3": "Identifies some errors but incomplete",
            "1": "Misses errors or incorrect analysis",
            "0": "No error analysis"
          }
        },
        {
          "criterion": "Pattern Recognition",
          "weight": 0.4,
          "scoring": {
            "5": "Recognizes error patterns and recurring issues",
            "3": "Some pattern recognition",
            "1": "No pattern analysis",
            "0": "No pattern insights"
          }
        }
      ],
      "expectedScoreWithout": 30,
      "expectedScoreWith": 70
    },
    {
      "id": "bench-med-01",
      "difficulty": "medium",
      "description": "Configuration analysis with optimization recommendations",
      "input": "Analyze my OpenClaw configuration file. Is it optimized for my workload? I have 25 skills installed and run about 50 sessions per day with moderate complexity tasks.",
      "rubric": [
        {
          "criterion": "Config Analysis",
          "weight": 0.3,
          "scoring": {
            "5": "Thorough analysis of all config fields with workload-appropriate assessment",
            "3": "Analyzes main config areas",
            "1": "Surface-level analysis",
            "0": "No meaningful analysis"
          }
        },
        {
          "criterion": "Optimization Recommendations",
          "weight": 0.4,
          "scoring": {
            "5": "Specific recommendations (concurrency, timeouts, memory) justified by workload",
            "3": "General recommendations without specifics",
            "1": "Generic suggestions",
            "0": "No optimization advice"
          }
        },
        {
          "criterion": "Explanation",
          "weight": 0.3,
          "scoring": {
            "5": "Clear rationale connecting workload to recommendations",
            "3": "Some explanation provided",
            "1": "Weak or unclear explanation",
            "0": "No explanation"
          }
        }
      ],
      "expectedScoreWithout": 35,
      "expectedScoreWith": 75
    },
    {
      "id": "bench-med-02",
      "difficulty": "medium",
      "description": "Performance analysis with bottleneck identification",
      "input": "My OpenClaw feels sluggish lately. Sessions take longer than usual and sometimes timeout. Can you analyze what might be causing performance issues?",
      "rubric": [
        {
          "criterion": "Diagnostic Approach",
          "weight": 0.3,
          "scoring": {
            "5": "Systematic check of memory, CPU, concurrency, disk I/O, and skill load times",
            "3": "Checks several performance factors",
            "1": "Limited diagnostic scope",
            "0": "No systematic approach"
          }
        },
        {
          "criterion": "Bottleneck Identification",
          "weight": 0.4,
          "scoring": {
            "5": "Identifies specific bottleneck with evidence and quantified impact",
            "3": "Points to likely bottleneck but weak evidence",
            "1": "Generic performance complaints",
            "0": "No bottleneck identified"
          }
        },
        {
          "criterion": "Solutions",
          "weight": 0.3,
          "scoring": {
            "5": "Specific solutions with expected improvement",
            "3": "General solutions suggested",
            "1": "Vague suggestions",
            "0": "No solutions offered"
          }
        }
      ],
      "expectedScoreWithout": 35,
      "expectedScoreWith": 70
    },
    {
      "id": "bench-med-03",
      "difficulty": "medium",
      "description": "Dependency analysis and conflict resolution",
      "input": "I'm trying to install @botlearn/social-media but it says there's a dependency conflict. Help me understand what's wrong and how to fix it.",
      "rubric": [
        {
          "criterion": "Problem Analysis",
          "weight": 0.4,
          "scoring": {
            "5": "Identifies specific conflict (skill versions, dependency versions) with clear explanation",
            "3": "Partially identifies conflict",
            "1": "Unclear about the conflict",
            "0": "Doesn't understand the issue"
          }
        },
        {
          "criterion": "Resolution Options",
          "weight": 0.4,
          "scoring": {
            "5": "Multiple resolution options with pros/cons and recommended approach",
            "3": "One solution provided",
            "1": "Vague guidance",
            "0": "No solution offered"
          }
        },
        {
          "criterion": "Execution Guidance",
          "weight": 0.2,
          "scoring": {
            "5": "Step-by-step commands to resolve",
            "3": "General guidance",
            "1": "Unclear steps",
            "0": "No actionable guidance"
          }
        }
      ],
      "expectedScoreWithout": 30,
      "expectedScoreWith": 70
    },
    {
      "id": "bench-med-04",
      "difficulty": "medium",
      "description": "Workspace analysis and organization recommendations",
      "input": "Analyze my OpenClaw workspace. I have lots of files and projects accumulated. Help me understand what I have and suggest better organization.",
      "rubric": [
        {
