          }
        },
        {
          "criterion": "Cleanup Guidance",
          "weight": 0.2,
          "scoring": {
            "5": "Identifies files for cleanup/archive with safe removal guidance",
            "3": "Some cleanup suggestions",
            "1": "Minimal cleanup guidance",
            "0": "No cleanup advice"
          }
        }
      ],
      "expectedScoreWithout": 30,
      "expectedScoreWith": 70
    },
    {
      "id": "bench-hard-01",
      "difficulty": "hard",
      "description": "Complex multi-issue diagnostic with cascading problems",
      "input": "My OpenClaw has multiple issues: it crashes randomly, some skills don't load, and logs show strange errors. I recently upgraded Node.js and installed several new skills. Help me untangle this mess.",
      "rubric": [
        {
          "criterion": "Root Cause Analysis",
          "weight": 0.35,
          "scoring": {
            "5": "Identifies root cause chain (e.g., Node version → skill incompatibility → crash) with evidence",
            "3": "Partial root cause analysis",
            "1": "Surface symptoms only",
            "0": "Incorrect analysis"
          }
        },
        {
          "criterion": "Issue Prioritization",
          "weight": 0.25,
          "scoring": {
            "5": "Correctly prioritizes issues by severity and dependency order",
            "3": "Some prioritization logic",
            "1": "Poor prioritization",
            "0": "No prioritization"
          }
        },
        {
          "criterion": "Resolution Plan",
          "weight": 0.25,
          "scoring": {
            "5": "Step-by-step resolution plan addressing root causes with rollback for each step",
            "3": "Basic resolution plan",
            "1": "Incomplete plan",
            "0": "No actionable plan"
          }
        },
        {
          "criterion": "System Thinking",
          "weight": 0.15,
          "scoring": {
            "5": "Demonstrates understanding of component interactions and cascading effects",
            "3": "Some system thinking evident",
            "1": "Treats issues in isolation",
            "0": "No system understanding"
          }
        }
      ],
      "expectedScoreWithout": 25,
      "expectedScoreWith": 70
    },
    {
      "id": "bench-hard-02",
      "difficulty": "hard",
      "description": "Security audit with vulnerability assessment",
      "input": "Perform a security audit of my OpenClaw installation. Check for exposed credentials, insecure configurations, outdated dependencies with known vulnerabilities, and any other security concerns.",
      "rubric": [
        {
