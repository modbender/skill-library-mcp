{
  "name": "agent-avengers",
  "version": "1.0.0",
  "description": "올인원 멀티에이전트 오케스트레이션 - 자동 분해, 생성, 실행, 통합",
  "author": "oozoofrog",
  "keywords": ["multi-agent", "orchestration", "automation", "avengers"],
