{
  "models": {
    "providers": {
      "$LLM_PROVIDER": {
        "baseUrl": "$LLM_BASE_URL",
        "apiKey": "$LLM_API_KEY",
        "api": "$LLM_API_FORMAT",
        "models": [
          {
            "id": "$MODEL_FAST",
            "name": "Fast Model",
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "$MODEL_STRONG",
            "name": "Strong Model",
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "$HOME/clawd",
      "model": { "primary": "$LLM_PROVIDER/$MODEL_FAST" },
      "maxConcurrent": 4,
      "subagents": { "maxConcurrent": 8 }
    },
    "list": [
      {
        "id": "main",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_FAST" },
        "identity": {
          "name": "司礼监",
          "theme": "你是司礼监掌印太监大内总管。批红传旨、居中调度、统领内廷。说话简练干脆，自称奴婢。调用其他部门时套用模板：【角色】+【任务】+【背景】+【要求】+【格式】。",
          "emoji": "⚡"
        },
        "subagents": {
          "allowAgents": ["bingbu", "hubu", "libu", "gongbu", "libu2", "xingbu"]
        }
      },
      {
        "id": "bingbu",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_STRONG" },
        "identity": {
          "name": "兵部尚书",
          "theme": "你是兵部尚书。负责软件工程、系统架构、部署作战。说话果断如军令，自称本部或臣。",
          "emoji": "⚔️"
        }
      },
      {
        "id": "hubu",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_STRONG" },
        "identity": {
          "name": "户部尚书",
          "theme": "你是户部尚书。负责财务预算、成本管控。精打细算锱铢必较，自称臣，总想省钱。",
          "emoji": "💰"
        }
      },
      {
        "id": "libu",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_FAST" },
        "identity": {
          "name": "礼部尚书",
          "theme": "你是礼部尚书。负责品牌建设、社交媒体、公关礼仪。文雅讲究注重体面，自称臣。",
          "emoji": "🎭"
        }
      },
      {
        "id": "gongbu",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_FAST" },
        "identity": {
          "name": "工部尚书",
          "theme": "你是工部尚书。负责基础设施、DevOps、服务器运维。实在务实爱谈技术，自称臣。",
          "emoji": "🔧"
        }
      },
      {
        "id": "libu2",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_FAST" },
        "identity": {
          "name": "吏部尚书",
          "theme": "你是吏部尚书。负责人事考核、团队管理。严肃公正知人善任，自称臣。",
          "emoji": "👔"
        }
      },
      {
        "id": "xingbu",
        "model": { "primary": "$LLM_PROVIDER/$MODEL_FAST" },
        "identity": {
          "name": "刑部尚书",
          "theme": "你是刑部尚书。负责合规、法律、合同审查、风控。严谨引用法条，自称臣。",
          "emoji": "⚖️"
        }
      }
    ]
  },
  "channels": {
    "discord": {
      "enabled": true,
      "groupPolicy": "open",
      "historyLimit": 20,
      "accounts": {
        "main":   { "name": "司礼监",   "token": "$DISCORD_BOT_TOKEN_MAIN",   "groupPolicy": "open" },
        "bingbu": { "name": "兵部尚书", "token": "$DISCORD_BOT_TOKEN_BINGBU", "groupPolicy": "open" },
        "hubu":   { "name": "户部尚书", "token": "$DISCORD_BOT_TOKEN_HUBU",   "groupPolicy": "open" },
        "libu":   { "name": "礼部尚书", "token": "$DISCORD_BOT_TOKEN_LIBU",   "groupPolicy": "open" },
        "gongbu": { "name": "工部尚书", "token": "$DISCORD_BOT_TOKEN_GONGBU", "groupPolicy": "open" },
        "libu2":  { "name": "吏部尚书", "token": "$DISCORD_BOT_TOKEN_LIBU2",  "groupPolicy": "open" },
        "xingbu": { "name": "刑部尚书", "token": "$DISCORD_BOT_TOKEN_XINGBU", "groupPolicy": "open" }
      },
      "guilds": {
        "$DISCORD_GUILD_ID": {
          "requireMention": true
        }
      }
    }
  },
  "bindings": [
    { "agentId": "main",   "match": { "channel": "discord", "accountId": "main" } },
    { "agentId": "bingbu", "match": { "channel": "discord", "accountId": "bingbu" } },
    { "agentId": "hubu",   "match": { "channel": "discord", "accountId": "hubu" } },
    { "agentId": "libu",   "match": { "channel": "discord", "accountId": "libu" } },
    { "agentId": "gongbu", "match": { "channel": "discord", "accountId": "gongbu" } },
    { "agentId": "libu2",  "match": { "channel": "discord", "accountId": "libu2" } },
    { "agentId": "xingbu", "match": { "channel": "discord", "accountId": "xingbu" } }
  ],
  "messages": {
    "ackReactionScope": "group-mentions"
  }
}
