{
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "content": "📝 信息收集", "tag": "plain_text" },
    "template": "blue"
  },
  "elements": [
    {
      "tag": "div",
      "text": {
        "content": "**请填写以下信息**",
        "tag": "lark_md"
      }
    },
    {
      "tag": "hr"
    },
    {
      "tag": "form",
      "name": "user_form",
      "elements": [
        {
          "tag": "div",
          "text": { "content": "**姓名**", "tag": "lark_md" }
        },
        {
          "tag": "input",
          "name": "name",
          "placeholder": { "content": "请输入姓名", "tag": "plain_text" },
          "max_length": 50
        },
        {
          "tag": "div",
          "text": { "content": "", "tag": "plain_text" }
        },
        {
          "tag": "div",
          "text": { "content": "**邮箱**", "tag": "lark_md" }
        },
        {
          "tag": "input",
          "name": "email",
          "placeholder": { "content": "请输入邮箱", "tag": "plain_text" },
          "max_length": 100
        },
        {
          "tag": "div",
          "text": { "content": "", "tag": "plain_text" }
        },
        {
          "tag": "div",
          "text": { "content": "**部门**", "tag": "lark_md" }
        },
        {
          "tag": "select_static",
          "name": "department",
          "placeholder": { "content": "选择部门", "tag": "plain_text" },
          "options": [
            { "text": { "content": "技术部", "tag": "plain_text" }, "value": "tech" },
            { "text": { "content": "产品部", "tag": "plain_text" }, "value": "product" },
            { "text": { "content": "运营部", "tag": "plain_text" }, "value": "operations" },
            { "text": { "content": "市场部", "tag": "plain_text" }, "value": "marketing" }
          ]
        },
        {
          "tag": "div",
          "text": { "content": "", "tag": "plain_text" }
        },
        {
          "tag": "div",
          "text": { "content": "**备注**", "tag": "lark_md" }
        },
        {
          "tag": "textarea",
          "name": "notes",
          "placeholder": { "content": "其他信息（可选）", "tag": "plain_text" },
          "max_length": 500,
          "rows": 3
        }
      ]
    },
    {
      "tag": "hr"
    },
    {
      "tag": "action",
      "actions": [
        {
          "tag": "button",
          "text": { "content": "✅ 提交", "tag": "plain_text" },
          "type": "primary",
          "value": { "action": "submit_form" }
        },
        {
          "tag": "button",
          "text": { "content": "❌ 取消", "tag": "plain_text" },
          "type": "default",
          "value": { "action": "cancel" }
        }
      ]
    }
  ]
}
