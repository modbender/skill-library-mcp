{
  "name": "skill-library-mcp",
  "version": "3.0.0",
  "description": "MCP server providing on-demand skill loading for AI coding assistants",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/modbender/skill-library-mcp"
  },
  "homepage": "https://github.com/modbender/skill-library-mcp#readme",
  "bugs": {
    "url": "https://github.com/modbender/skill-library-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "skills",
    "claude",
    "claude-code",
    "ai",
    "llm",
    "coding-assistant",
    "skill-library",
    "mcp-server"
  ],
  "files": [
    "dist/",
    "data/*/SKILL.md",
    "data/*/resources/*.md",
    ".claude-plugin/",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "skill-library-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsx scripts/sync-version.ts && tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:integration": "vitest run test/integration.test.ts test/dedup.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dedup": "tsx src/dedup.ts data/",
    "validate-skills": "tsx scripts/validate-skills.ts data/",
    "clean-skills": "tsx scripts/clean-skills.ts data/",
    "fix-skills": "tsx scripts/fix-skills.ts data/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "yaml": "^2.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
